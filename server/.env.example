# Option A — project root .env.local (with VITE_* keys): same vars work here.
# Option B — this file as server/.env or server/.env.local
#
# Load order (later overrides earlier): project .env → .env.local → server/.env → server/.env.local
# X Developer Portal → Project → Keys → Bearer Token (not Consumer Keys).
X_BEARER_TOKEN=
# Optional alias (same value as X_BEARER_TOKEN):
# TWITTER_BEARER_TOKEN=
# Comma or space separated, no @
X_FEED_HANDLES=

# Optional — must match Vite proxy (see vite.config + project .env.local)
X_FEED_PORT=8787
PORT=8787
X_FEED_MAX_PER_USER=5
X_FEED_CACHE_SECONDS=120

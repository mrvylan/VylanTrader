# Copy to `.env.local` and restart `npm run dev`.
# Finnhub (free): https://finnhub.io/register
VITE_FINNHUB_API_KEY=

# Recommended: Finnhub free tier often returns 403 on daily candles — add AV as backup:
# https://www.alphavantage.co/support/#api-key
# VITE_ALPHA_VANTAGE_API_KEY=

# Optional: force mock data
# VITE_MARKET_DATA=mock
